PORT=5000
CLIENT_URL=http://localhost:5173
# Base URL used to build invite accept links (defaults to CLIENT_URL).
PUBLIC_APP_URL=http://localhost:5173
SUPABASE_URL=https://ymsooxqtwlttpqjnmumb.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# Service-role / secret key — REQUIRED for invites (server-side only, never expose).
SUPABASE_SECRET_KEY=sb_secret_your_key_here
# Comma-separated bootstrap admins who can send invites (invited admins also work via role).
ADMIN_EMAILS=you@yourcompany.com
# --- Email (optional). Without any of this, invites still work via shareable link. ---
# Option A (no domain needed): SMTP, e.g. Gmail with an App Password. Sends to anyone.
#   For Gmail: enable 2-Step Verification, then create an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_16_char_app_password
# Option B: Resend API. The shared test sender only emails the Resend account owner;
#   verify a domain at resend.com/domains to email anyone.
RESEND_API_KEY=re_your_key_here
# From address. For SMTP defaults to your SMTP_USER; for a verified Resend domain use it here.
EMAIL_FROM=Voice Agent OS <you@gmail.com>
